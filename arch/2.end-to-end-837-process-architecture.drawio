        </mxCell>
        <mxCell id="n316" value="✓ Fast duplicate detection using XXH3 fingerprint + DynamoDB (metadata driven).&#10;✓ Supports New, Replacement and Void business scenarios.&#10;✓ Optimal storage tiering with Hot (Operational DB) or Cold (Historical Storage).&#10;✓ Status of existing record is updated and corrected/void file is processed freshly.&#10;✓ Cost optimized storage using S3 + Iceberg for historical data.&#10;✓ Scalable, reliable and fully monitored serverless architecture." style="text;html=1;whiteSpace=wrap;fontSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="1492" width="680" height="110" as="geometry" />
